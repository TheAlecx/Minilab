// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db { 
  provider = "postgresql"
} 

model Product {
id String @id @default ( cuid () ) // Identifiant unique auto -ééégnr
name String // Nom du produit
description String ? // Description optionnelle (? = nullable )
price Decimal // Prix du produit ( type Decimal pour la éprcision )
createdAt DateTime @default ( now () ) // Date de écration automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
cartItems CartItem [] // Relation : un produit peut être dans plusieurs paniers
}

// èModle Cart : éreprsente un panier d ’ achat
model Cart {
id String @id @default ( cuid () ) // Identifiant unique auto -ééégnr
userId String // Identifiant de l ’ utilisateur propréitaire
createdAt DateTime @default ( now () ) // Date de écration automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
items CartItem [] // Relation : un panier contient plusieurs articles
}

// Modèle CartItem : éreprsente un article dans un panier ( table de liaison )
model CartItem {
id String @id @default ( cuid () ) // Identifiant unique auto - généré
quantity Int // éQuantit de ce produit dans le panier
cartId String // éCl éètrangre vers Cart
cart Cart @relation ( fields : [ cartId ] , references : [ id ]) // Relation vers Cart
productId String // éCl éètrangre vers Product
product Product @relation ( fields : [ productId ] , references : [ id ]) // Relation vers Product
}
